{
  "compilerOptions": {
    "module": "commonjs",
    "target": "es6",
    "outDir": "app",
    "lib": ["es6"],
    "sourceMap": true,
    "rootDir": "src/ts",
    "skipLibCheck": true,
    "strict": true,
    "moduleResolution": "node16",
    "noUnusedLocals": true
  },
  "exclude": ["node_modules", "dist"]
}
